# Configure o envio real de e-mail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seuemail@gmail.com
EMAIL_HOST_PASSWORD=sua_senha_de_app_do_gmail
DEFAULT_FROM_EMAIL=seuemail@gmail.com

# Hosts permitidos para acesso local ou em rede interna
# Exemplo: DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.0.10
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
